# 이 파일을 복사해 .env 로 만들고 값을 채운다. (.env 는 git 추적 제외)
# docker-compose가 .env를 자동으로 읽고, Spring 앱은 run.ps1이 OS 환경변수로 로드한다.

# MySQL (docker-compose + 앱 datasource 공용)
MYSQL_DATABASE=commerce
MYSQL_USER=commerce
MYSQL_PASSWORD=change-me-strong-password
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# JWT 서명 시크릿 (HS384 → 48바이트 이상 권장)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-48-bytes
