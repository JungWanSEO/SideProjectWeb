# ── 빌드 & Gradle (모든 모듈) ──
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# ── IDE ──
.idea/
*.iml
*.iws
*.ipr
# VSCode: settings.json 은 개인 설정(예: claudeCode.*)이 섞여 추적 제외.
#         launch.json(공유 디버그 설정)은 계속 추적.
.vscode/settings.json

# ── OS ──
.DS_Store
Thumbs.db

# ── 로그 ──
*.log

# ── 환경/시크릿 ──
.env
*.env.local

# ── 프론트엔드 (예정) ──
node_modules/
dist/
.next/

# 참고: backend/.gradle, backend/build 는 위 규칙으로 무시됨.
#       .claude/, docs/, CLAUDE.md 는 추적 대상(프로젝트 자산).
